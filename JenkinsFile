pipeline {
    agent any
    environment {
        NETLIFY_SITE_ID= '2c474009-e93b-42f3-b2af-ce4c4d3ffdee'
        NETLIFY_AUTH_TOKEN= credentials('netlify_token')
    }
    stages {
        stage('Build') {
                agent
                {
                    docker
                    {
                        image 'node:18-alpine'
                        reuseNode true
                    }
                }
         steps
         {
             sh '''
             ls -la
             npm --version
             node --version
             npm ci
             npm run build
             '''
         }
            
        }

        stage('Test')
        {
             agent
                {
                    docker
                    {
                        image 'node:18-alpine'
                        reuseNode true
                    }
                }
                steps
                {
                    sh '''
                    echo 'Testing phase'
                    npm test
                    '''
                }
        }
         stage('E2E')
        {
             agent
                {
                    docker
                    {
                        image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                        reuseNode true
                    }
                }
                steps
                {
                    sh '''
                    echo 'End to End Testing phase'
                    npm install serve
                    node_modules/.bin/serve -s build &
                    sleep 10
                    npx playwright test --reporter=html
                    '''
                }
        }
         stage('UAT Deploy') {
                agent
                {
                    docker
                    {
                        image 'node:18-alpine'
                        reuseNode true
                    }
                }
         steps
         {
             sh '''
                echo 'Deploying the application'
                npm install netlify-cli@20.1.1
                node_modules/.bin/netlify --version
                 node_modules/.bin/netlify deploy --dir=build --prod > deploy_output.json
                echo 'Deployment URL:'
                
                
             '''
             script
         {
            env.url = sh(script:"node_modules/.bin/node-jq -r '.deploy_url' deploy_output.json",returnStdout: true))
         }
         }
         
            
        }
         stage('UAT Tests')
        {
             agent
                {
                    docker
                    {
                        image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                        reuseNode true
                    }
                }
                environment {
                    CI_ENVIRONMENT_URL = "${env.url}"
                }
                steps
                {
                    sh '''
                    echo 'End to End Testing phase in production'
                    npx playwright test --reporter=html
                    '''
                }
                 {
        always
        {
            publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'Playwright UAT HTML Report', reportTitles: '', useWrapperFileDirectly: true])
        }
    }
        }
        stage('Approval')
        {
            steps
            {
                timeout(time: 2, unit: 'MINUTES') {
                    input message: 'Approve deployment to production?', ok: 'Deploy'
                }
            }

        }
        stage('Deploy') {
                agent
                {
                    docker
                    {
                        image 'node:18-alpine'
                        reuseNode true
                    }
                }
         steps
         {
             sh '''
                echo 'Deploying the application'
                npm install netlify-cli@20.1.1 node-jq
                node_modules/.bin/netlify --version
                echo 'Deploying to Netlify with siete id: $NETLIFY_SITE_ID'
                

             '''
         }
            
        }
        stage('Prod Tests')
        {
             agent
                {
                    docker
                    {
                        image 'mcr.microsoft.com/playwright:v1.39.0-jammy'
                        reuseNode true
                    }
                }
                environment {
                    CI_ENVIRONMENT_URL = "https://profound-dango-14ffe6.netlify.app"
                }
                steps
                {
                    sh '''
                    echo 'End to End Testing phase in production'
                    npx playwright test --reporter=html
                    '''
                }
        }
    }
    post
    {
        always
        {
            junit 'jest-results/junit.xml'
            publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'playwright-report', reportFiles: 'index.html', reportName: 'Playwright Prod HTML Report', reportTitles: '', useWrapperFileDirectly: true])
        }
    }
}
